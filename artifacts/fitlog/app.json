{
  "expo": {
    "name": "Ordeal",
    "slug": "fitlog",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "fitlog",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0f0f1a"
    },
    "ios": {
      "supportsTablet": false,
      "buildNumber": "12",
      "bundleIdentifier": "com.yesha.fitlog",
      "infoPlist": {
        "NSHealthShareUsageDescription": "Ordeal reads your steps, heart rate, and sleep to give your AI coach accurate recovery data.",
        "NSHealthUpdateUsageDescription": "Ordeal writes your workouts and water intake to Apple Health.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.yesha.fitlog",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0f0f1a"
      }
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "bundler": "metro",
      "name": "Ordeal – AI Fitness Tracker",
      "shortName": "Ordeal",
      "description": "Your personal AI-powered fitness companion — workouts, nutrition, coaching and progress tracking.",
      "themeColor": "#00e676",
      "backgroundColor": "#0f0f1a",
      "lang": "en",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      [
        "react-native-health-connect",
        {
          "permissions": [
            "android.permission.health.READ_STEPS",
            "android.permission.health.READ_SLEEP",
            "android.permission.health.READ_HEART_RATE",
            "android.permission.health.WRITE_EXERCISE",
            "android.permission.health.WRITE_HYDRATION"
          ]
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#00e676",
          "androidMode": "default",
          "androidCollapsedTitle": "Ordeal",
          "iosDisplayInForeground": true
        }
      ],
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e50ad49b-f5fa-448d-a7ab-9537a44b442a"
      }
    },
    "owner": "hamdan777"
  }
}
