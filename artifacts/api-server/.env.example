# ─────────────────────────────────────────────
# FitLog API Server – local development config
# ─────────────────────────────────────────────
# Copy this file to .env and fill in the values:
#   cp .env.example .env

# Port the Express server listens on
PORT=3001

# Node environment
NODE_ENV=development

# ── Database ──────────────────────────────────
# Paste your Supabase connection string here.
# Get it from: Supabase Dashboard → Settings → Database → URI
# It looks like: postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres
# Leave empty to use embedded PGlite for local development.
DATABASE_URL=

# ── AI features (optional) ────────────────────
# Without this key the app works fine; only AI photo scan,
# coach chat, and meal plan generation will be unavailable.
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# ── CORS ──────────────────────────────────────
# Leave empty – Expo Go on a real device sends no Origin header
# so all native requests are allowed automatically.
CORS_ORIGIN=
